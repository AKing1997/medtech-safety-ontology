<?xml version="1.0"?>
<rdf:RDF xmlns="file:///home/scarulli/chowlk_project/Chowlk/httpns/httpns/"
     xml:base="file:///home/scarulli/chowlk_project/Chowlk/httpns/httpns/"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:httpns="file:///home/scarulli/chowlk_project/Chowlk/httpns/">
    <owl:Ontology rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/httpns/">
        <rdfs:comment xml:lang="en">Ontology for the MDR/IVDR regulatory framework representing Devices, Manufacturers, Incidents, Risks, and Corrective Actions.</rdfs:comment>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/mod#createdWith -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/mod#createdWith"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/addressesIncident -->


    <owl:ObjectProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/addressesIncident">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/FSCA"/>
        <rdfs:range rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Incident"/>
        <rdfs:comment xml:lang="en">Connects a corrective action (FSCA) to the incident it addresses.</rdfs:comment>
        <rdfs:label xml:lang="en">addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/affectsDeviceType -->


    <owl:ObjectProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/affectsDeviceType">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk"/>
        <rdfs:range rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Device"/>
        <rdfs:comment xml:lang="en">Links a specific risk category to the types of devices it generally affects.</rdfs:comment>
        <rdfs:label xml:lang="en">affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/associatedWithRisk -->


    <owl:ObjectProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/associatedWithRisk">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Incident"/>
        <rdfs:range rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk"/>
        <rdfs:comment xml:lang="en">Links an incident to the identified IMDRF risk category.</rdfs:comment>
        <rdfs:label xml:lang="en">associated with risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/hasManufacturer -->


    <owl:ObjectProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/hasManufacturer">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Device"/>
        <rdfs:range rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Manufacturer"/>
        <rdfs:comment xml:lang="en">Links a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/involvesDevice -->


    <owl:ObjectProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/involvesDevice">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Incident"/>
        <rdfs:range rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Device"/>
        <rdfs:comment xml:lang="en">Indicates the medical device involved in a specific incident.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/manufacturesDevice -->


    <owl:ObjectProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/manufacturesDevice">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Manufacturer"/>
        <rdfs:range rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Device"/>
        <rdfs:comment xml:lang="en">Links a manufacturer to the devices it produces (Inverse of hasManufacturer).</rdfs:comment>
        <rdfs:label xml:lang="en">manufactures device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/reportedBy -->


    <owl:ObjectProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/reportedBy">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Incident"/>
        <rdfs:range rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Manufacturer"/>
        <rdfs:comment xml:lang="en">Identifies the manufacturer that reported the incident to EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/severity -->


    <owl:ObjectProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/severity">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk"/>
        <rdfs:comment xml:lang="en">The severity level of a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/action_date -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/action_date">
        <rdfs:comment xml:lang="en">The date when the corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">action_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/authorization_number -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/authorization_number">
        <rdfs:comment xml:lang="en">The regulatory authorization number of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">authorization_number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/closure_date -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/closure_date">
        <rdfs:comment xml:lang="en">The date when the corrective action was officially closed.</rdfs:comment>
        <rdfs:label xml:lang="en">closure_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/competent_authority -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/competent_authority">
        <rdfs:comment xml:lang="en">The national authority overseeing the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">competent_authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/contact_email -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/contact_email">
        <rdfs:comment xml:lang="en">Contact email for the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">contact_email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/corrective_action_taken -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/corrective_action_taken">
        <rdfs:comment xml:lang="en">Indicates if a corrective action was taken following the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">corrective_action_taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/countries_affected -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/countries_affected">
        <rdfs:comment xml:lang="en">List of countries affected by the incident or FSCA.</rdfs:comment>
        <rdfs:label xml:lang="en">countries_affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/country -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/country">
        <rdfs:comment xml:lang="en">The country of origin for the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/country_reported -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/country_reported">
        <rdfs:comment xml:lang="en">The country where the incident occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">country_reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/description -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/description">
        <rdfs:comment xml:lang="en">A textual description of the event, risk, or action.</rdfs:comment>
        <rdfs:label xml:lang="en">description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/detection_date -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/detection_date">
        <rdfs:comment xml:lang="en">The date when the incident was first detected.</rdfs:comment>
        <rdfs:label xml:lang="en">detection_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/device_id -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/device_id">
        <rdfs:comment xml:lang="en">The unique internal identifier for the device.</rdfs:comment>
        <rdfs:label xml:lang="en">device_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/device_name -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/device_name">
        <rdfs:comment xml:lang="en">The commercial name of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">device_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/devices_affected -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/devices_affected">
        <rdfs:comment xml:lang="en">The number of device units affected by a recall or alert.</rdfs:comment>
        <rdfs:label xml:lang="en">devices_affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_fsca_ref -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_fsca_ref">
        <rdfs:comment xml:lang="en">The official EUDAMED reference number for the FSCA.</rdfs:comment>
        <rdfs:label xml:lang="en">eudamed_fsca_ref</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_incident_ref -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_incident_ref">
        <rdfs:comment xml:lang="en">The official EUDAMED reference number for the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">eudamed_incident_ref</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_srn -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_srn">
        <rdfs:comment xml:lang="en">The Single Registration Number of the manufacturer in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">eudamed_srn</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/event_date -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/event_date">
        <rdfs:comment xml:lang="en">The exact date the adverse event took place.</rdfs:comment>
        <rdfs:label xml:lang="en">event_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/fsca_id -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/fsca_id">
        <rdfs:comment xml:lang="en">The unique identifier for the Field Safety Corrective Action.</rdfs:comment>
        <rdfs:label xml:lang="en">fsca_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/imdrf_code -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/imdrf_code">
        <rdfs:comment xml:lang="en">The official IMDRF code identifying the type of risk or event.</rdfs:comment>
        <rdfs:label xml:lang="en">imdrf_code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/incident_id -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/incident_id">
        <rdfs:comment xml:lang="en">The unique identifier for the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">incident_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/intended_purpose -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/intended_purpose">
        <rdfs:comment xml:lang="en">The medical purpose for which the device is intended.</rdfs:comment>
        <rdfs:label xml:lang="en">intended_purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/is_active -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/is_active">
        <rdfs:domain rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveDevice"/>
        <rdfs:comment xml:lang="en">Boolean flag indicating if the device is active (powered).</rdfs:comment>
        <rdfs:label xml:lang="en">is_active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/is_implantable -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/is_implantable">
        <rdfs:comment xml:lang="en">Boolean flag indicating if the device is implantable.</rdfs:comment>
        <rdfs:label xml:lang="en">is_implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/is_ivd -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/is_ivd">
        <rdfs:comment xml:lang="en">Boolean flag indicating if the device is an IVD.</rdfs:comment>
        <rdfs:label xml:lang="en">is_ivd</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/is_reusable -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/is_reusable">
        <rdfs:comment xml:lang="en">Boolean flag indicating if the device is reusable.</rdfs:comment>
        <rdfs:label xml:lang="en">is_reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/manufacturer_id -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/manufacturer_id">
        <rdfs:comment xml:lang="en">The unique identifier for the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">manufacturer_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/name -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/name">
        <rdfs:comment xml:lang="en">The name of the entity.</rdfs:comment>
        <rdfs:label xml:lang="en">name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/outcome -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/outcome">
        <rdfs:comment xml:lang="en">The clinical outcome of the patient following the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/patient_age -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/patient_age">
        <rdfs:comment xml:lang="en">The age of the patient involved in the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">patient_age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/patient_sex -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/patient_sex">
        <rdfs:comment xml:lang="en">The biological sex of the patient.</rdfs:comment>
        <rdfs:label xml:lang="en">patient_sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/probability -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/probability">
        <rdfs:comment xml:lang="en">The likelihood of the risk occurring.</rdfs:comment>
        <rdfs:label xml:lang="en">probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/regulatory_framework -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/regulatory_framework">
        <rdfs:comment xml:lang="en">The legal framework applicable to the device (e.g., MDR or IVDR).</rdfs:comment>
        <rdfs:label xml:lang="en">regulatory_framework</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/report_date -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/report_date">
        <rdfs:comment xml:lang="en">The date when the incident was reported to authorities.</rdfs:comment>
        <rdfs:label xml:lang="en">report_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_category -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_category">
        <rdfs:comment xml:lang="en">The overarching category of the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">risk_category</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_class -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_class">
        <rdfs:comment xml:lang="en">The regulatory risk classification of the device (e.g., Class III).</rdfs:comment>
        <rdfs:label xml:lang="en">risk_class</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_id -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_id">
        <rdfs:comment xml:lang="en">The unique identifier for the risk record.</rdfs:comment>
        <rdfs:label xml:lang="en">risk_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_name -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_name">
        <rdfs:comment xml:lang="en">The specific name of the identified risk.</rdfs:comment>
        <rdfs:label xml:lang="en">risk_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/scope -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/scope">
        <rdfs:comment xml:lang="en">The scope of affected products in an FSCA.</rdfs:comment>
        <rdfs:label xml:lang="en">scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/status -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/status">
        <rdfs:comment xml:lang="en">The current status of the incident or FSCA (e.g., Open, Closed).</rdfs:comment>
        <rdfs:label xml:lang="en">status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/udi_di -->


    <owl:DatatypeProperty rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/udi_di">
        <rdfs:comment xml:lang="en">The Unique Device Identifier - Device Identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">udi_di</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveDevice -->


    <owl:Class rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveDevice">
        <rdfs:subClassOf rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/Device"/>
        <owl:disjointWith rdf:resource="file:///home/scarulli/chowlk_project/Chowlk/httpns/InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">A medical device that relies on a source of electrical energy or any source of power.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveImplant -->


    <owl:Class rdf:about="file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveImplant">
