@prefix : <file:///home/scarulli/chowlk_project/Chowlk/httpns/httpns/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <file:///home/scarulli/chowlk_project/Chowlk/httpns/httpns/> .

<file:///home/scarulli/chowlk_project/Chowlk/httpns/httpns/> rdf:type owl:Ontology ;
                                                              rdfs:comment "Ontology for the MDR/IVDR regulatory framework representing Devices, Manufacturers, Incidents, Risks, and Corrective Actions."@en ;
                                                              <https://w3id.org/mod#createdWith> <https://chowlk.linkeddata.es/> .

#################################################################
#    Annotation properties
#################################################################

###  https://w3id.org/mod#createdWith
<https://w3id.org/mod#createdWith> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  file:///home/scarulli/chowlk_project/Chowlk/httpns/addressesIncident
<file:///home/scarulli/chowlk_project/Chowlk/httpns/addressesIncident> rdf:type owl:ObjectProperty ;
                                                                       rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/FSCA> ;
                                                                       rdfs:range <file:///home/scarulli/chowlk_project/Chowlk/httpns/Incident> ;
                                                                       rdfs:comment "Connects a corrective action (FSCA) to the incident it addresses."@en ;
                                                                       rdfs:label "addresses incident"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/affectsDeviceType
<file:///home/scarulli/chowlk_project/Chowlk/httpns/affectsDeviceType> rdf:type owl:ObjectProperty ;
                                                                       rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk> ;
                                                                       rdfs:range <file:///home/scarulli/chowlk_project/Chowlk/httpns/Device> ;
                                                                       rdfs:comment "Links a specific risk category to the types of devices it generally affects."@en ;
                                                                       rdfs:label "affects device type"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/associatedWithRisk
<file:///home/scarulli/chowlk_project/Chowlk/httpns/associatedWithRisk> rdf:type owl:ObjectProperty ;
                                                                        rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/Incident> ;
                                                                        rdfs:range <file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk> ;
                                                                        rdfs:comment "Links an incident to the identified IMDRF risk category."@en ;
                                                                        rdfs:label "associated with risk"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/hasManufacturer
<file:///home/scarulli/chowlk_project/Chowlk/httpns/hasManufacturer> rdf:type owl:ObjectProperty ;
                                                                     rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/Device> ;
                                                                     rdfs:range <file:///home/scarulli/chowlk_project/Chowlk/httpns/Manufacturer> ;
                                                                     rdfs:comment "Links a medical device to its manufacturer."@en ;
                                                                     rdfs:label "has manufacturer"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/involvesDevice
<file:///home/scarulli/chowlk_project/Chowlk/httpns/involvesDevice> rdf:type owl:ObjectProperty ;
                                                                    rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/Incident> ;
                                                                    rdfs:range <file:///home/scarulli/chowlk_project/Chowlk/httpns/Device> ;
                                                                    rdfs:comment "Indicates the medical device involved in a specific incident."@en ;
                                                                    rdfs:label "involves device"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/manufacturesDevice
<file:///home/scarulli/chowlk_project/Chowlk/httpns/manufacturesDevice> rdf:type owl:ObjectProperty ;
                                                                        rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/Manufacturer> ;
                                                                        rdfs:range <file:///home/scarulli/chowlk_project/Chowlk/httpns/Device> ;
                                                                        rdfs:comment "Links a manufacturer to the devices it produces (Inverse of hasManufacturer)."@en ;
                                                                        rdfs:label "manufactures device"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/reportedBy
<file:///home/scarulli/chowlk_project/Chowlk/httpns/reportedBy> rdf:type owl:ObjectProperty ;
                                                                rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/Incident> ;
                                                                rdfs:range <file:///home/scarulli/chowlk_project/Chowlk/httpns/Manufacturer> ;
                                                                rdfs:comment "Identifies the manufacturer that reported the incident to EUDAMED."@en ;
                                                                rdfs:label "reported by"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/severity
<file:///home/scarulli/chowlk_project/Chowlk/httpns/severity> rdf:type owl:ObjectProperty ;
                                                              rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk> ;
                                                              rdfs:comment "The severity level of a risk."@en ;
                                                              rdfs:label "severity"@en .


