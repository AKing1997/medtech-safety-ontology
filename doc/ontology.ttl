                                                                         rdfs:comment "The national authority overseeing the manufacturer."@en ;
                                                                         rdfs:label "competent_authority"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/contact_email
<file:///home/scarulli/chowlk_project/Chowlk/httpns/contact_email> rdf:type owl:DatatypeProperty ;
                                                                   rdfs:comment "Contact email for the manufacturer."@en ;
                                                                   rdfs:label "contact_email"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/corrective_action_taken
<file:///home/scarulli/chowlk_project/Chowlk/httpns/corrective_action_taken> rdf:type owl:DatatypeProperty ;
                                                                             rdfs:comment "Indicates if a corrective action was taken following the incident."@en ;
                                                                             rdfs:label "corrective_action_taken"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/countries_affected
<file:///home/scarulli/chowlk_project/Chowlk/httpns/countries_affected> rdf:type owl:DatatypeProperty ;
                                                                        rdfs:comment "List of countries affected by the incident or FSCA."@en ;
                                                                        rdfs:label "countries_affected"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/country
<file:///home/scarulli/chowlk_project/Chowlk/httpns/country> rdf:type owl:DatatypeProperty ;
                                                             rdfs:comment "The country of origin for the manufacturer."@en ;
                                                             rdfs:label "country"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/country_reported
<file:///home/scarulli/chowlk_project/Chowlk/httpns/country_reported> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:comment "The country where the incident occurred."@en ;
                                                                      rdfs:label "country_reported"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/description
<file:///home/scarulli/chowlk_project/Chowlk/httpns/description> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "A textual description of the event, risk, or action."@en ;
                                                                 rdfs:label "description"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/detection_date
<file:///home/scarulli/chowlk_project/Chowlk/httpns/detection_date> rdf:type owl:DatatypeProperty ;
                                                                    rdfs:comment "The date when the incident was first detected."@en ;
                                                                    rdfs:label "detection_date"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/device_id
<file:///home/scarulli/chowlk_project/Chowlk/httpns/device_id> rdf:type owl:DatatypeProperty ;
                                                               rdfs:comment "The unique internal identifier for the device."@en ;
                                                               rdfs:label "device_id"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/device_name
<file:///home/scarulli/chowlk_project/Chowlk/httpns/device_name> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "The commercial name of the medical device."@en ;
                                                                 rdfs:label "device_name"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/devices_affected
<file:///home/scarulli/chowlk_project/Chowlk/httpns/devices_affected> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:comment "The number of device units affected by a recall or alert."@en ;
                                                                      rdfs:label "devices_affected"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_fsca_ref
<file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_fsca_ref> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:comment "The official EUDAMED reference number for the FSCA."@en ;
                                                                      rdfs:label "eudamed_fsca_ref"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_incident_ref
<file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_incident_ref> rdf:type owl:DatatypeProperty ;
                                                                          rdfs:comment "The official EUDAMED reference number for the incident."@en ;
                                                                          rdfs:label "eudamed_incident_ref"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_srn
<file:///home/scarulli/chowlk_project/Chowlk/httpns/eudamed_srn> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "The Single Registration Number of the manufacturer in EUDAMED."@en ;
                                                                 rdfs:label "eudamed_srn"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/event_date
<file:///home/scarulli/chowlk_project/Chowlk/httpns/event_date> rdf:type owl:DatatypeProperty ;
                                                                rdfs:comment "The exact date the adverse event took place."@en ;
                                                                rdfs:label "event_date"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/fsca_id
<file:///home/scarulli/chowlk_project/Chowlk/httpns/fsca_id> rdf:type owl:DatatypeProperty ;
                                                             rdfs:comment "The unique identifier for the Field Safety Corrective Action."@en ;
                                                             rdfs:label "fsca_id"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/imdrf_code
<file:///home/scarulli/chowlk_project/Chowlk/httpns/imdrf_code> rdf:type owl:DatatypeProperty ;
                                                                rdfs:comment "The official IMDRF code identifying the type of risk or event."@en ;
                                                                rdfs:label "imdrf_code"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/incident_id
<file:///home/scarulli/chowlk_project/Chowlk/httpns/incident_id> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "The unique identifier for the incident."@en ;
                                                                 rdfs:label "incident_id"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/intended_purpose
<file:///home/scarulli/chowlk_project/Chowlk/httpns/intended_purpose> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:comment "The medical purpose for which the device is intended."@en ;
                                                                      rdfs:label "intended_purpose"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/is_active
<file:///home/scarulli/chowlk_project/Chowlk/httpns/is_active> rdf:type owl:DatatypeProperty ;
                                                               rdfs:domain <file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveDevice> ;
                                                               rdfs:comment "Boolean flag indicating if the device is active (powered)."@en ;
                                                               rdfs:label "is_active"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/is_implantable
<file:///home/scarulli/chowlk_project/Chowlk/httpns/is_implantable> rdf:type owl:DatatypeProperty ;
                                                                    rdfs:comment "Boolean flag indicating if the device is implantable."@en ;
                                                                    rdfs:label "is_implantable"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/is_ivd
<file:///home/scarulli/chowlk_project/Chowlk/httpns/is_ivd> rdf:type owl:DatatypeProperty ;
                                                            rdfs:comment "Boolean flag indicating if the device is an IVD."@en ;
                                                            rdfs:label "is_ivd"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/is_reusable
<file:///home/scarulli/chowlk_project/Chowlk/httpns/is_reusable> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "Boolean flag indicating if the device is reusable."@en ;
                                                                 rdfs:label "is_reusable"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/manufacturer_id
<file:///home/scarulli/chowlk_project/Chowlk/httpns/manufacturer_id> rdf:type owl:DatatypeProperty ;
                                                                     rdfs:comment "The unique identifier for the manufacturer."@en ;
                                                                     rdfs:label "manufacturer_id"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/name
<file:///home/scarulli/chowlk_project/Chowlk/httpns/name> rdf:type owl:DatatypeProperty ;
                                                          rdfs:comment "The name of the entity."@en ;
                                                          rdfs:label "name"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/outcome
<file:///home/scarulli/chowlk_project/Chowlk/httpns/outcome> rdf:type owl:DatatypeProperty ;
                                                             rdfs:comment "The clinical outcome of the patient following the incident."@en ;
                                                             rdfs:label "outcome"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/patient_age
<file:///home/scarulli/chowlk_project/Chowlk/httpns/patient_age> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "The age of the patient involved in the incident."@en ;
                                                                 rdfs:label "patient_age"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/patient_sex
<file:///home/scarulli/chowlk_project/Chowlk/httpns/patient_sex> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "The biological sex of the patient."@en ;
                                                                 rdfs:label "patient_sex"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/probability
<file:///home/scarulli/chowlk_project/Chowlk/httpns/probability> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "The likelihood of the risk occurring."@en ;
                                                                 rdfs:label "probability"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/regulatory_framework
<file:///home/scarulli/chowlk_project/Chowlk/httpns/regulatory_framework> rdf:type owl:DatatypeProperty ;
                                                                          rdfs:comment "The legal framework applicable to the device (e.g., MDR or IVDR)."@en ;
                                                                          rdfs:label "regulatory_framework"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/report_date
<file:///home/scarulli/chowlk_project/Chowlk/httpns/report_date> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:comment "The date when the incident was reported to authorities."@en ;
                                                                 rdfs:label "report_date"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_category
<file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_category> rdf:type owl:DatatypeProperty ;
                                                                   rdfs:comment "The overarching category of the risk."@en ;
                                                                   rdfs:label "risk_category"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_class
<file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_class> rdf:type owl:DatatypeProperty ;
                                                                rdfs:comment "The regulatory risk classification of the device (e.g., Class III)."@en ;
                                                                rdfs:label "risk_class"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_id
<file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_id> rdf:type owl:DatatypeProperty ;
                                                             rdfs:comment "The unique identifier for the risk record."@en ;
                                                             rdfs:label "risk_id"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_name
<file:///home/scarulli/chowlk_project/Chowlk/httpns/risk_name> rdf:type owl:DatatypeProperty ;
                                                               rdfs:comment "The specific name of the identified risk."@en ;
                                                               rdfs:label "risk_name"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/scope
<file:///home/scarulli/chowlk_project/Chowlk/httpns/scope> rdf:type owl:DatatypeProperty ;
                                                           rdfs:comment "The scope of affected products in an FSCA."@en ;
                                                           rdfs:label "scope"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/status
<file:///home/scarulli/chowlk_project/Chowlk/httpns/status> rdf:type owl:DatatypeProperty ;
                                                            rdfs:comment "The current status of the incident or FSCA (e.g., Open, Closed)."@en ;
                                                            rdfs:label "status"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/udi_di
<file:///home/scarulli/chowlk_project/Chowlk/httpns/udi_di> rdf:type owl:DatatypeProperty ;
                                                            rdfs:comment "The Unique Device Identifier - Device Identifier."@en ;
                                                            rdfs:label "udi_di"@en .


#################################################################
#    Classes
#################################################################

###  file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveDevice
<file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveDevice> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <file:///home/scarulli/chowlk_project/Chowlk/httpns/Device> ;
                                                                  owl:disjointWith <file:///home/scarulli/chowlk_project/Chowlk/httpns/InVitroDiagnosticDevice> ;
                                                                  rdfs:comment "A medical device that relies on a source of electrical energy or any source of power."@en ;
                                                                  rdfs:label "Active Device"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveImplant
<file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveImplant> rdf:type owl:Class ;
                                                                   rdfs:subClassOf <file:///home/scarulli/chowlk_project/Chowlk/httpns/ImplantableDevice> ;
                                                                   rdfs:comment "An implantable device that relies on an energy source."@en ;
                                                                   rdfs:label "Active Implant"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/ContaminationRisk
<file:///home/scarulli/chowlk_project/Chowlk/httpns/ContaminationRisk> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk> ;
                                                                       rdfs:comment "Risk arising from biological or chemical contamination of the device."@en ;
                                                                       rdfs:label "Contamination Risk"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/CybersecurityRisk
<file:///home/scarulli/chowlk_project/Chowlk/httpns/CybersecurityRisk> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk> ;
                                                                       rdfs:comment "Risk arising from software vulnerabilities or unauthorized access."@en ;
                                                                       rdfs:label "Cybersecurity Risk"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/Device
<file:///home/scarulli/chowlk_project/Chowlk/httpns/Device> rdf:type owl:Class ;
                                                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <file:///home/scarulli/chowlk_project/Chowlk/httpns/hasManufacturer> ;
                                                                              owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                            ] ;
                                                            rdfs:comment "A medical device according to the MDR/IVDR regulatory framework."@en ;
                                                            rdfs:label "Device"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/DiagnosticRisk
<file:///home/scarulli/chowlk_project/Chowlk/httpns/DiagnosticRisk> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <file:///home/scarulli/chowlk_project/Chowlk/httpns/Risk> ;
                                                                    rdfs:comment "Risk related to false positives or false negatives in IVD devices."@en ;
                                                                    rdfs:label "Diagnostic Risk"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/FSCA
<file:///home/scarulli/chowlk_project/Chowlk/httpns/FSCA> rdf:type owl:Class ;
                                                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                            owl:onProperty <file:///home/scarulli/chowlk_project/Chowlk/httpns/addressesIncident> ;
                                                                            owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                          ] ;
                                                          rdfs:comment "Field Safety Corrective Action taken to mitigate a risk."@en ;
                                                          rdfs:label "F S C A"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/ImplantableActiveDevice
<file:///home/scarulli/chowlk_project/Chowlk/httpns/ImplantableActiveDevice> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <file:///home/scarulli/chowlk_project/Chowlk/httpns/ActiveDevice> ;
                                                                             rdfs:comment "An active medical device which is intended to be totally or partially introduced into the human body."@en ;
                                                                             rdfs:label "Implantable Active Device"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/ImplantableDevice
<file:///home/scarulli/chowlk_project/Chowlk/httpns/ImplantableDevice> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <file:///home/scarulli/chowlk_project/Chowlk/httpns/Device> ;
                                                                       rdfs:comment "A device intended to be totally introduced into the human body through clinical intervention."@en ;
                                                                       rdfs:label "Implantable Device"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/InSituCorrection
<file:///home/scarulli/chowlk_project/Chowlk/httpns/InSituCorrection> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <file:///home/scarulli/chowlk_project/Chowlk/httpns/FSCA> ;
                                                                      rdfs:comment "Action taken to correct or update a device without removing it from the user."@en ;
                                                                      rdfs:label "In Situ Correction"@en .


###  file:///home/scarulli/chowlk_project/Chowlk/httpns/InVitroDiagnosticDevice
